# ---- Gemini API ----
# Free tier for gemini-3.5-flash: tokens are free, limited to 15 RPM / 1500 RPD.
# NEVER commit your real key. Copy this file to `.env` and fill it in.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.5-flash

# ---- Orchestration ----
MAX_ITERATIONS=2          # max critic -> revise loops (loop guard)
ENABLE_THINKING=true      # use Gemini thinking + capture thought summaries
TEMPERATURE=1.0

# ---- Rate limiting / resilience (stay safely under free-tier caps) ----
RPM_LIMIT=12              # < 15 requests/min
RPD_LIMIT=1400            # < 1500 requests/day
MAX_RETRIES=5             # retry-with-backoff on 429/5xx
REQUEST_TIMEOUT_S=120

# ---- CORS ----
# Default (if unset) is ["*"] — fine for this app: public, unauthenticated, no cookies.
# Override here only if you want to lock dev down to specific origins instead.
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
