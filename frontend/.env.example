# Backend base URL
VITE_API_BASE=http://localhost:8000

# Firebase (optional — only needed for the "Share Drama" public-link feature).
# These are web client config values; still kept out of source via .env.
# Copy this file to `.env` and fill from your Firebase console. Leave blank to disable sharing.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
